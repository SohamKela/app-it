<Window x:Class="AppItWindows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="App"
        Height="820" Width="1280"
        WindowStartupLocation="CenterScreen">
    <!-- Minimal by design: a single WebView2 fills the window. Title and Icon
         are set in code-behind from the config passed in (HostConfig), so the
         taskbar entry is the app, not Edge. -->
    <Grid>
        <wv2:WebView2 x:Name="Web" />
    </Grid>
</Window>
